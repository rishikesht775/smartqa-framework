<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SmartQA Hybrid Suite" parallel="tests" thread-count="3">

    <!-- 🔥 Selenium - Chrome -->
    <test name="Selenium Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="runners.TestRunner"/>
        </classes>
    </test>

    <!-- 🔥 Selenium - Edge -->
    <test name="Selenium Edge">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="runners.TestRunner"/>
        </classes>
    </test>

    <!-- 🔥 Playwright - Chromium -->
    <test name="Playwright Chromium">
        <parameter name="browser" value="chromium"/>
        <classes>
            <class name="runners.TestRunner"/>
        </classes>
    </test>

</suite>